<apex:page showHeader="false" sidebar="false" standardStylesheets="false" applyHtmlTag="false" applyBodyTag="false" docType="html-5.0">
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Doctor Referral Management</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Segoe UI',Arial,sans-serif}
body{background:#eef2f7;color:#0f172a;padding:18px}
h1{font-size:20px;color:#0b3d2e;margin-bottom:16px}
.kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:16px}
.kpi{background:#fff;border-radius:14px;border:1px solid #e7ecf3;padding:16px;box-shadow:0 4px 14px rgba(0,0,0,.06)}
.kpi .v{font-size:26px;font-weight:bold;color:#0b3d2e}
.kpi .l{font-size:12px;color:#64748b;margin-top:4px}
.kpi .t{font-size:11px;color:#0F9D58;margin-top:6px;font-weight:bold}
.cols{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.card{background:#fff;border-radius:16px;box-shadow:0 4px 14px rgba(0,0,0,.06);border:1px solid #e7ecf3;padding:18px;margin-bottom:16px}
.card h3{font-size:14px;color:#0b3d2e;margin-bottom:14px;text-transform:uppercase;letter-spacing:.5px}
.bar-row{display:flex;align-items:center;gap:10px;margin-bottom:10px;font-size:13px}
.bar-row .lab{width:130px;color:#334155}
.bar-track{flex:1;background:#f1f5f9;border-radius:8px;height:18px;overflow:hidden}
.bar-fill{height:100%;background:linear-gradient(90deg,#0F9D58,#34d399);border-radius:8px}
.bar-row .num{width:30px;text-align:right;font-weight:bold;color:#0b3d2e}
.trend{display:flex;align-items:flex-end;gap:10px;height:160px;padding-top:10px}
.tcol{flex:1;display:flex;flex-direction:column;align-items:center;gap:6px;height:100%;justify-content:flex-end}
.tbar{width:100%;background:linear-gradient(180deg,#34d399,#0F9D58);border-radius:6px 6px 0 0}
.tcol .m{font-size:11px;color:#64748b}
.tcol .vv{font-size:11px;font-weight:bold;color:#0b3d2e}
table{width:100%;border-collapse:collapse;font-size:13px}
th{text-align:left;color:#64748b;font-weight:600;padding:8px;border-bottom:2px solid #eef2f7;font-size:11px;text-transform:uppercase}
td{padding:8px;border-bottom:1px solid #f1f5f9}
.pill{padding:3px 9px;border-radius:20px;font-size:11px;font-weight:bold}
.p-new{background:#dbeafe;color:#1d4ed8}.p-completed{background:#dcfce7;color:#15803d}.p-scheduled{background:#fef3c7;color:#b45309}.p-visit{background:#e0e7ff;color:#4338ca}.p-declined{background:#fee2e2;color:#b91c1c}
.rank{display:flex;align-items:center;gap:10px;padding:10px 0;border-bottom:1px solid #f1f5f9}
.rank .pos{width:26px;height:26px;border-radius:50%;background:#0b3d2e;color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:bold}
.rank .nm{flex:1;font-size:13px;font-weight:600}
.rank .sp{font-size:11px;color:#64748b}
.rank .ct{font-weight:bold;color:#0F9D58}
label{font-size:12px;color:#64748b;display:block;margin:8px 0 4px}
input,select,textarea{width:100%;border:1px solid #cbd5e1;border-radius:8px;padding:9px;font-size:13px}
.btn{background:#0F9D58;color:#fff;border:none;border-radius:10px;padding:10px 16px;font-weight:bold;cursor:pointer;font-size:13px;margin-top:12px}
.btn.ghost{background:#fff;color:#0b3d2e;border:1px solid #0F9D58}
.task{display:flex;gap:10px;align-items:center;padding:9px 0;border-bottom:1px solid #f1f5f9;font-size:13px}
.task .due{margin-left:auto;font-size:11px;color:#64748b}
.task .done{color:#0F9D58;cursor:pointer;font-size:12px;margin-left:8px}
.summary{background:#0b3d2e;color:#fff;border-radius:14px;padding:18px;font-size:13px;line-height:1.6;display:none}
.summary h4{color:#a7f3d0;margin-bottom:8px}
.newrow{background:#ecfdf5}
/* toast */
.toast-wrap{position:fixed;top:16px;right:16px;z-index:99999;display:flex;flex-direction:column;gap:10px;max-width:90vw}
.toast{min-width:220px;max-width:340px;background:#0b3d2e;color:#fff;padding:12px 14px;border-radius:12px;box-shadow:0 10px 30px rgba(0,0,0,.28);font-size:13px;line-height:1.4;display:flex;align-items:flex-start;gap:10px;border-left:4px solid #0F9D58;animation:toastIn .25s ease;transition:opacity .3s,transform .3s}
.toast.info{border-left-color:#2563eb}.toast.error{border-left-color:#dc2626}.toast .ti{font-size:16px;line-height:1}
@keyframes toastIn{from{opacity:0;transform:translateX(40px)}to{opacity:1;transform:none}}
@media(max-width:560px){.toast-wrap{top:auto;bottom:14px;right:50%;transform:translateX(50%)}}
/* responsive */
@media(max-width:600px){body{padding:12px}.kpis{grid-template-columns:1fr 1fr}.cols{grid-template-columns:1fr}table{font-size:12px}}
@media(max-width:380px){.kpis{grid-template-columns:1fr}}
</style>
</head>
<body>
<h1>&#129489;&#8205;&#9877; Doctor Referral Management</h1>

<div class="kpis" id="kpis"></div>

<div class="cols">
  <div class="card">
    <h3>Referral Volume by Specialization</h3>
    <div id="specBars"></div>
  </div>
  <div class="card">
    <h3>Most Referred Doctors</h3>
    <div id="topDocs"></div>
  </div>
</div>

<div class="card">
  <h3>Monthly Referral Trend</h3>
  <div class="trend" id="trend"></div>
</div>

<div class="cols">
  <div class="card">
    <h3>Log a Referral / Visit</h3>
    <div class="cols">
      <div>
        <label>Referring Doctor / HCP</label><input id="rfFrom" value="Dr. Sajan Thomas (Caritas Hospital)"/>
        <label>Specialization</label>
        <select id="rfSpec"><option>Cardiology</option><option>Oncology</option><option>Nephrology</option><option>Neurology</option><option>Orthopedics</option><option>Pediatrics</option><option>ENT</option><option>General Medicine</option></select>
      </div>
      <div>
        <label>Referred To Doctor</label>
        <select id="rfTo"><option>Dr. Thomas George</option><option>Dr. Anjali Nair</option><option>Dr. Rahul Menon</option><option>Dr. Priya Varghese</option><option>Dr. Suresh Kumar</option></select>
        <label>Patient</label><input id="rfPat" value="New Referral Patient"/>
      </div>
    </div>
    <button class="btn" onclick="logReferral()">Log Referral</button>
    <button class="btn ghost" onclick="addReminder()">+ Set Reminder</button>
  </div>

  <div class="card">
    <h3>Tasks &amp; Reminders</h3>
    <div id="tasks"></div>
  </div>
</div>

<div class="card">
  <h3>Recent Referrals</h3>
  <table><thead><tr><th>Ref #</th><th>Referring HCP</th><th>To Doctor</th><th>Specialization</th><th>Date</th><th>Status</th></tr></thead>
  <tbody id="refBody"></tbody></table>
</div>

<div class="card">
  <h3>On-demand HCP Summary</h3>
  <label>Select HCP / Referring Doctor</label>
  <select id="hcpSel" style="max-width:340px">
    <option>Dr. Sajan Thomas (Caritas Hospital)</option>
    <option>Dr. Maya Pillai (Lakeshore)</option>
    <option>City Clinic</option>
  </select>
  <button class="btn" onclick="genSummary()">Generate HCP Summary</button>
  <div class="summary" id="summary"></div>
</div>

<script>
//<![CDATA[
function showToast(msg,type){
  type=type||'success';var icon=type==='error'?'⚠':(type==='info'?'ℹ':'✅');
  var w=document.getElementById('toastWrap');
  if(!w){w=document.createElement('div');w.id='toastWrap';w.className='toast-wrap';document.body.appendChild(w);}
  var t=document.createElement('div');t.className='toast '+type;
  t.innerHTML='<span class="ti">'+icon+'</span><span>'+String(msg).replace(/\n/g,'<br/>')+'</span>';
  w.appendChild(t);
  setTimeout(function(){t.style.opacity='0';t.style.transform='translateX(40px)';setTimeout(function(){if(t.parentNode)t.parentNode.removeChild(t);},320);},3600);
}
// ---- persistent stores ----
var RKEY='bcmch_referrals',TKEY='bcmch_tasks';
function loadR(){try{return JSON.parse(localStorage.getItem(RKEY))||[];}catch(e){return [];}}
function saveR(a){try{localStorage.setItem(RKEY,JSON.stringify(a));}catch(e){}}
function loadT(){try{return JSON.parse(localStorage.getItem(TKEY))||null;}catch(e){return null;}}
function saveT(a){try{localStorage.setItem(TKEY,JSON.stringify(a));}catch(e){}}

// seed referrals (baseline) + persisted (user-logged) on top
var SEED_REFS=[
 {ref:'HREF0042',from:'Dr. Sajan Thomas',to:'Dr. Thomas George',spec:'Cardiology',date:'10 Jun 2026',status:'New'},
 {ref:'HREF0041',from:'Dr. Maya Pillai',to:'Dr. Anjali Nair',spec:'Oncology',date:'08 Jun 2026',status:'Scheduled'},
 {ref:'HREF0040',from:'City Clinic',to:'Dr. Suresh Kumar',spec:'Orthopedics',date:'06 Jun 2026',status:'Completed'},
 {ref:'HREF0039',from:'Dr. Rajan Nair',to:'Dr. Rahul Menon',spec:'Nephrology',date:'04 Jun 2026',status:'Visit Logged'},
 {ref:'HREF0038',from:'Holy Family Hosp.',to:'Dr. Priya Varghese',spec:'Neurology',date:'01 Jun 2026',status:'Completed'}
];
var DEFAULT_TASKS=[
 {txt:'Follow up with Dr. Sajan Thomas on cardiology referral',due:'Due today'},
 {txt:'Send HCP summary to Caritas Hospital',due:'Tomorrow'},
 {txt:'Confirm oncology slot for referred patient',due:'14 Jun'}
];
var BASE_TREND=[['Jan',14],['Feb',18],['Mar',21],['Apr',16],['May',22],['Jun',37]];
var BASE_TOTAL=128;

function allRefs(){return loadR().concat(SEED_REFS);}
function pillClass(s){s=s.toLowerCase();return s==='completed'?'p-completed':s==='scheduled'?'p-scheduled':s.indexOf('visit')>-1?'p-visit':s==='declined'?'p-declined':'p-new';}

function renderKpis(){
  var added=loadR().length;
  var pendingFollow=12+loadR().filter(function(r){return r.status==='New';}).length;
  document.getElementById('kpis').innerHTML=
    kpi(BASE_TOTAL+added,'Total Referrals (YTD)','▲ 14% vs last qtr')+
    kpi(37+added,'This Month','▲ '+(8+added)+' new this week')+
    kpi(pendingFollow,'Pending Follow-up','3 due today')+
    kpi(8,'Referring HCPs','across 6 districts');
}
function kpi(v,l,t){return '<div class="kpi"><div class="v">'+v+'</div><div class="l">'+l+'</div><div class="t">'+t+'</div></div>';}

function renderBars(){
  var counts={'Cardiology':34,'Oncology':26,'Orthopedics':21,'Nephrology':18,'Neurology':12,'Pediatrics':9,'ENT':8,'General Medicine':4};
  loadR().forEach(function(r){counts[r.spec]=(counts[r.spec]||0)+1;});
  var arr=[];for(var k in counts)arr.push([k,counts[k]]);
  arr.sort(function(a,b){return b[1]-a[1];});
  var max=arr[0][1];
  document.getElementById('specBars').innerHTML=arr.map(function(s){
    return '<div class="bar-row"><div class="lab">'+s[0]+'</div><div class="bar-track"><div class="bar-fill" style="width:'+(s[1]/max*100)+'%"></div></div><div class="num">'+s[1]+'</div></div>';
  }).join('');
}
function renderTopDocs(){
  var counts={'Dr. Thomas George|Cardiology':31,'Dr. Anjali Nair|Oncology':24,'Dr. Suresh Kumar|Orthopedics':19,'Dr. Rahul Menon|Nephrology':16,'Dr. Priya Varghese|Neurology':11};
  loadR().forEach(function(r){var key=r.to+'|'+r.spec;counts[key]=(counts[key]||0)+1;});
  var arr=[];for(var k in counts)arr.push([k.split('|')[0],k.split('|')[1],counts[k]]);
  arr.sort(function(a,b){return b[2]-a[2];});
  document.getElementById('topDocs').innerHTML=arr.slice(0,5).map(function(d,i){
    return '<div class="rank"><div class="pos">'+(i+1)+'</div><div><div class="nm">'+d[0]+'</div><div class="sp">'+d[1]+'</div></div><div class="ct">'+d[2]+'</div></div>';
  }).join('');
}
function renderTrend(){
  var trend=BASE_TREND.map(function(t){return [t[0],t[1]];});
  trend[trend.length-1][1]+=loadR().length; // current month grows with new referrals
  var tmax=Math.max.apply(null,trend.map(function(t){return t[1];}));
  document.getElementById('trend').innerHTML=trend.map(function(t){
    return '<div class="tcol"><div class="vv">'+t[1]+'</div><div class="tbar" style="height:'+(t[1]/tmax*100)+'%"></div><div class="m">'+t[0]+'</div></div>';
  }).join('');
}
function renderTable(){
  var rows=allRefs();var persistedCount=loadR().length;
  document.getElementById('refBody').innerHTML=rows.map(function(r,i){
    var cls=i<persistedCount?' class="newrow"':'';
    return '<tr'+cls+'><td>'+r.ref+'</td><td>'+r.from+'</td><td>'+r.to+'</td><td>'+r.spec+'</td><td>'+r.date+'</td><td><span class="pill '+pillClass(r.status)+'">'+r.status+'</span></td></tr>';
  }).join('');
}
function renderTasks(){
  var tasks=loadT();if(tasks===null){tasks=DEFAULT_TASKS.slice();saveT(tasks);}
  document.getElementById('tasks').innerHTML=tasks.map(function(t,i){
    return '<div class="task">&#9711; '+t.txt+'<span class="due">'+t.due+'</span><span class="done" onclick="completeTask('+i+')">Done</span></div>';
  }).join('')||'<div class="hint" style="color:#94a3b8;font-size:13px">No pending tasks.</div>';
}
function renderAll(){renderKpis();renderBars();renderTopDocs();renderTrend();renderTable();renderTasks();}

function todayStr(){var m=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];var d=new Date();return (d.getDate()<10?'0'+d.getDate():d.getDate())+' '+m[d.getMonth()]+' '+d.getFullYear();}
function nextRefNo(){return 'HREF'+(43+loadR().length);}
function logReferral(){
  var r={ref:nextRefNo(),from:document.getElementById('rfFrom').value,to:document.getElementById('rfTo').value,spec:document.getElementById('rfSpec').value,date:todayStr(),status:'New',patient:document.getElementById('rfPat').value};
  var a=loadR();a.unshift(r);saveR(a);renderAll();
  showToast('Referral '+r.ref+' logged & saved\n'+r.from+' → '+r.to);
}
function addReminder(){
  var tasks=loadT()||DEFAULT_TASKS.slice();
  tasks.unshift({txt:'Follow up referral from '+document.getElementById('rfFrom').value,due:'In 3 days'});
  saveT(tasks);renderTasks();
  showToast('Reminder task created & saved','info');
}
function completeTask(i){
  var tasks=loadT()||DEFAULT_TASKS.slice();var t=tasks[i];tasks.splice(i,1);saveT(tasks);renderTasks();
  showToast('Task completed'+(t?(': '+t.txt):''));
}
function genSummary(){
  var hcp=document.getElementById('hcpSel').value;
  var extra=loadR().filter(function(r){return r.from===hcp||hcp.indexOf(r.from)>-1;}).length;
  var s=document.getElementById('summary');s.style.display='block';
  s.innerHTML='<h4>HCP Summary &#8212; '+hcp+'</h4>'+
    'Total referrals sent: <b>'+(23+extra)+'</b> &#8226; Last 90 days: <b>'+(9+extra)+'</b><br/>'+
    'Top specializations: Cardiology (11), Oncology (7), Orthopedics (5)<br/>'+
    'Conversion to appointment: <b>87%</b> &#8226; Avg response time: <b>1.4 days</b><br/>'+
    'Most referred to: Dr. Thomas George, Dr. Anjali Nair<br/>'+
    'Relationship: <b>Active partner</b> since 2021 &#8226; District: Kottayam<br/>'+
    'Recommended action: Schedule quarterly HCP visit &amp; share outcome report.';
  showToast('HCP summary generated','info');
}
renderAll();
//]]>
</script>
</body>
</html>
</apex:page>
