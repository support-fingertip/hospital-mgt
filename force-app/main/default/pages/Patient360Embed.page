<apex:page standardController="Lead__c" showHeader="false" sidebar="false" standardStylesheets="false" applyHtmlTag="false" applyBodyTag="false" docType="html-5.0">
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Patient 360 Snapshot</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Segoe UI',Arial,sans-serif}
body{background:transparent;color:#0f172a;padding:4px}
.wrap{display:flex;flex-direction:column;gap:14px}
.hero{background:linear-gradient(135deg,#0b3d2e,#0F9D58);color:#fff;border-radius:16px;padding:18px;display:flex;align-items:center;gap:16px;flex-wrap:wrap}
.hero .av{width:64px;height:64px;border-radius:50%;background:rgba(255,255,255,.18);border:2px solid rgba(255,255,255,.4);display:flex;align-items:center;justify-content:center;font-size:30px}
.hero .nm{font-size:20px;font-weight:bold}
.hero .meta{font-size:12px;color:#d1fae5;margin-top:3px}
.hero .badge{margin-left:auto;background:rgba(255,255,255,.18);border:1px solid rgba(255,255,255,.4);padding:6px 12px;border-radius:20px;font-size:12px;font-weight:bold;white-space:nowrap}
.kpis{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.kpi{background:#fff;border:1px solid #e7ecf3;border-radius:12px;padding:14px;text-align:center;box-shadow:0 3px 10px rgba(0,0,0,.05)}
.kpi .v{font-size:18px;font-weight:bold;color:#0b3d2e}
.kpi .l{font-size:11px;color:#64748b;margin-top:4px}
.cols2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.card{background:#fff;border:1px solid #e7ecf3;border-radius:14px;padding:16px;box-shadow:0 3px 10px rgba(0,0,0,.05)}
.card h3{font-size:12px;color:#0b3d2e;margin-bottom:10px;text-transform:uppercase;letter-spacing:.5px}
.kv{display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px dashed #eef2f7;font-size:13px;gap:10px}
.kv span:first-child{color:#64748b}
.kv span:last-child{font-weight:600;text-align:right}
.diag{font-size:13px;color:#334155;line-height:1.5}
.rel .card h3{margin-bottom:6px}
.rel table{width:100%;border-collapse:collapse;font-size:13px}
.rel th{text-align:left;color:#64748b;font-weight:600;padding:7px;border-bottom:2px solid #eef2f7;font-size:11px;text-transform:uppercase}
.rel td{padding:7px;border-bottom:1px solid #f1f5f9}
.rel a{color:#0F9D58;text-decoration:none;font-weight:600}
@media(max-width:700px){.kpis{grid-template-columns:1fr 1fr}.cols2{grid-template-columns:1fr}}
</style>
</head>
<body>
<div class="wrap">

  <div class="hero">
    <div class="av">&#129658;</div>
    <div>
      <div class="nm">{!Lead__c.Name} {!Lead__c.Last_Name__c}</div>
      <div class="meta">MRN {!Lead__c.Hospital_Number__c} &#8226; {!Lead__c.Age__c}y &#8226; {!Lead__c.Gender__c} &#8226; {!Lead__c.Blood_Group__c}</div>
    </div>
    <div class="badge">{!IF(ISBLANK(Lead__c.Patient_Category__c),"Patient",Lead__c.Patient_Category__c)} &#8226; {!Lead__c.Status__c}</div>
  </div>

  <div class="kpis">
    <div class="kpi"><div class="v">{!Lead__c.Status__c}</div><div class="l">Status</div></div>
    <div class="kpi"><div class="v">{!Lead__c.Patient_Category__c}</div><div class="l">Category</div></div>
    <div class="kpi"><div class="v"><apex:outputText value="{0,date,dd MMM yyyy}"><apex:param value="{!Lead__c.Follow_up_Date__c}"/></apex:outputText></div><div class="l">Next Follow-up</div></div>
    <div class="kpi"><div class="v"><apex:outputText value="{0,number,###,##0}"><apex:param value="{!Lead__c.Lifetime_Value__c}"/></apex:outputText></div><div class="l">Lifetime Value (&#8377;)</div></div>
  </div>

  <div class="cols2">
    <div class="card">
      <h3>Demographics &amp; Contact</h3>
      <div class="kv"><span>Mobile</span><span>{!Lead__c.Mobile__c}</span></div>
      <div class="kv"><span>Email</span><span>{!Lead__c.Email__c}</span></div>
      <div class="kv"><span>Preferred Contact</span><span>{!Lead__c.Preferred_Contact__c}</span></div>
      <div class="kv"><span>Occupation</span><span>{!Lead__c.Occupation__c}</span></div>
      <div class="kv"><span>Registered</span><span><apex:outputText value="{0,date,dd MMM yyyy}"><apex:param value="{!Lead__c.Registration_Date__c}"/></apex:outputText></span></div>
    </div>
    <div class="card">
      <h3>Clinical Summary</h3>
      <div class="kv"><span>Type</span><span>{!Lead__c.Type__c}</span></div>
      <div class="kv"><span>Primary Doctor</span><span>{!Lead__c.Doctor__r.Name}</span></div>
      <div class="kv"><span>Counsellor</span><span>{!Lead__c.Counsellor__r.Name}</span></div>
      <div class="kv"><span>Last Visit</span><span><apex:outputText value="{0,date,dd MMM yyyy}"><apex:param value="{!Lead__c.Last_Visit_Date__c}"/></apex:outputText></span></div>
      <div class="kv"><span>Last Admit</span><span><apex:outputText value="{0,date,dd MMM yyyy}"><apex:param value="{!Lead__c.Last_Admit_Date__c}"/></apex:outputText></span></div>
    </div>
  </div>

  <div class="card">
    <h3>Diagnosis</h3>
    <div class="diag">{!IF(ISBLANK(Lead__c.Diagnosis__c),"No diagnosis recorded.",Lead__c.Diagnosis__c)}</div>
  </div>

  <div class="cols2 rel">
    <div class="card">
      <h3>Appointments</h3>
      <apex:relatedList list="Appointments" subject="{!Lead__c}" rendered="true"/>
    </div>
    <div class="card">
      <h3>Calls</h3>
      <apex:relatedList list="Call" subject="{!Lead__c}" rendered="true"/>
    </div>
  </div>

  <div class="card rel">
    <h3>HCP Referrals</h3>
    <apex:relatedList list="HCP_Referrals" subject="{!Lead__c}" rendered="true"/>
  </div>

</div>
</body>
</html>
</apex:page>
