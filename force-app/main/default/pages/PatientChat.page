<apex:page showHeader="false" sidebar="false" standardStylesheets="false" applyHtmlTag="false" applyBodyTag="false" docType="html-5.0">
<html>
<head>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>BCMCH Web Chat</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:Arial,Helvetica,sans-serif}
body{background:#eef2f7;height:100vh;overflow:hidden}
.chat{height:100vh;display:flex;flex-direction:column;background:#fff}
.chat-head{background:#0b3d2e;color:#fff;padding:14px 16px;display:flex;align-items:center;gap:10px}
.avatar{width:40px;height:40px;border-radius:50%;background:#0F9D58;display:flex;align-items:center;justify-content:center;font-size:20px}
.chat-head .title{font-size:15px;font-weight:bold}
.chat-head .sub{font-size:11px;color:#a7f3d0}
.online{margin-left:auto;font-size:11px;background:#0F9D58;padding:4px 10px;border-radius:20px}
.messages{flex:1;overflow:auto;padding:16px;display:flex;flex-direction:column;gap:12px;background:#f8fafc}
.row{display:flex;gap:8px;max-width:85%}
.row.user{align-self:flex-end;flex-direction:row-reverse}
.bubble{padding:10px 14px;border-radius:16px;font-size:13px;line-height:1.45}
.bot .bubble{background:#fff;border:1px solid #e2e8f0;color:#111827;border-top-left-radius:4px}
.user .bubble{background:#0F9D58;color:#fff;border-top-right-radius:4px}
.mini-avatar{width:28px;height:28px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:14px}
.bot .mini-avatar{background:#d1fae5}
.user .mini-avatar{background:#0b3d2e;color:#fff}
.chips{display:flex;flex-wrap:wrap;gap:8px;padding:10px 16px;border-top:1px solid #e2e8f0;background:#fff}
.chip{background:#ecfdf5;color:#0b3d2e;border:1px solid #a7f3d0;border-radius:20px;padding:8px 12px;font-size:12px;font-weight:bold;cursor:pointer}
.chip:hover{background:#0F9D58;color:#fff}
.composer{display:flex;gap:8px;padding:12px 16px;border-top:1px solid #e2e8f0;background:#fff}
.composer input{flex:1;border:1px solid #cbd5e1;border-radius:24px;padding:10px 14px;font-size:13px;outline:none}
.composer button{background:#0F9D58;color:#fff;border:none;border-radius:50%;width:42px;height:42px;font-size:16px;cursor:pointer}
.typing{font-size:11px;color:#64748b;padding:0 16px 8px}

/* toast notifications */
.toast-wrap{position:fixed;top:16px;right:16px;z-index:99999;display:flex;flex-direction:column;gap:10px;max-width:90vw}
.toast{min-width:220px;max-width:340px;background:#0b3d2e;color:#fff;padding:12px 14px;border-radius:12px;box-shadow:0 10px 30px rgba(0,0,0,.28);font-size:13px;line-height:1.4;display:flex;align-items:flex-start;gap:10px;border-left:4px solid #0F9D58;animation:toastIn .25s ease;transition:opacity .3s,transform .3s}
.toast.info{border-left-color:#2563eb}
.toast.error{border-left-color:#dc2626}
.toast .ti{font-size:16px;line-height:1}
@keyframes toastIn{from{opacity:0;transform:translateX(40px)}to{opacity:1;transform:none}}
@media(max-width:560px){.toast-wrap{top:auto;bottom:14px;right:50%;transform:translateX(50%)}}

/* responsive */
@media(max-width:600px){
  body{padding:12px}
  .kpis{grid-template-columns:1fr 1fr}
  .grid,.cols,.cols2,.docs{grid-template-columns:1fr !important}
  .top{flex-direction:column;align-items:stretch}
  .top .sel,.top .btn{width:100%}
  table{font-size:12px}
  #calWrap{overflow-x:auto}
  .cal{min-width:540px}
  .modal-card{max-width:94vw}
}
@media(max-width:380px){.kpis{grid-template-columns:1fr}}
</style>
</head>
<body>
<div class="chat">
  <div class="chat-head">
    <div class="avatar">&#129658;</div>
    <div><div class="title">BCMCH Assistant</div><div class="sub">Believers Church Medical College Hospital</div></div>
    <div class="online">Online</div>
  </div>
  <div class="messages" id="messages">
    <div class="row bot"><div class="mini-avatar">&#129658;</div><div class="bubble">Hello! &#128075; I'm the BCMCH virtual assistant. How can I help you today?</div></div>
  </div>
  <div class="typing" id="typing" style="display:none">BCMCH Assistant is typing...</div>
  <div class="chips">
    <span class="chip" onclick="ask('Book an appointment')">Book an appointment</span>
    <span class="chip" onclick="ask('Find a doctor')">Find a doctor</span>
    <span class="chip" onclick="ask('Visiting hours')">Visiting hours</span>
    <span class="chip" onclick="ask('Emergency number')">Emergency</span>
    <span class="chip" onclick="ask('Talk to an agent')">Talk to an agent</span>
  </div>
  <div class="composer">
    <input type="text" id="userInput" placeholder="Type your message..." onkeypress="if(event.keyCode==13)send()"/>
    <button onclick="send()">&#10148;</button>
  </div>
</div>
<script>
//<![CDATA[
function showToast(msg,type){
  type=type||'success';
  var icon=type==='error'?'\u26A0':(type==='info'?'\u2139':'\u2705');
  var w=document.getElementById('toastWrap');
  if(!w){w=document.createElement('div');w.id='toastWrap';w.className='toast-wrap';document.body.appendChild(w);}
  var t=document.createElement('div');t.className='toast '+type;
  t.innerHTML='<span class="ti">'+icon+'</span><span>'+String(msg).replace(/\n/g,'<br/>')+'</span>';
  w.appendChild(t);
  setTimeout(function(){t.style.opacity='0';t.style.transform='translateX(40px)';setTimeout(function(){if(t.parentNode)t.parentNode.removeChild(t);},320);},3600);
}

var answers={
  'book an appointment':'Sure! You can book an appointment from the Appointment Scheduler. Which department do you need - Cardiology, Oncology, Nephrology, Pediatrics or General Medicine?',
  'find a doctor':'We have 15+ specialists across 8 departments. For example: Dr. Thomas George (Cardiology), Dr. Anjali Nair (Oncology), Dr. Meera Pillai (Pediatrics). Which specialization are you looking for?',
  'visiting hours':'Visiting hours at BCMCH are 11:00 AM - 1:00 PM and 4:00 PM - 7:00 PM daily. ICU visiting is restricted to 5:00 PM - 6:00 PM.',
  'emergency number':'For emergencies, please call our 24x7 Casualty: +91 469 273 0000. An ambulance can be dispatched immediately.',
  'talk to an agent':'Connecting you to a patient-care executive now. You can also call our contact center at +91 469 273 0000. ☎',
  'thanks':'You are most welcome! Wishing you good health from all of us at BCMCH. ❤',
  'hi':'Hi there! How may I assist you - appointments, doctors, reports or directions?'
};
function appendMsg(text,who){
  var m=document.getElementById('messages');
  var row=document.createElement('div');row.className='row '+who;
  var av=document.createElement('div');av.className='mini-avatar';av.innerHTML=who==='bot'?'🩺':'👤';
  var b=document.createElement('div');b.className='bubble';b.innerHTML=text;
  row.appendChild(av);row.appendChild(b);m.appendChild(row);m.scrollTop=m.scrollHeight;
}
function botReply(q){
  var key=q.toLowerCase().trim();
  var ans=answers[key];
  if(!ans){
    for(var k in answers){if(key.indexOf(k)>-1){ans=answers[k];break;}}
  }
  if(!ans)ans='I have noted your query: "'+q+'". A BCMCH patient-care executive will assist you shortly. Meanwhile you can use the quick options below.';
  document.getElementById('typing').style.display='block';
  setTimeout(function(){document.getElementById('typing').style.display='none';appendMsg(ans,'bot');},700);
}
function ask(q){appendMsg(q,'user');botReply(q);}
function send(){
  var i=document.getElementById('userInput');
  if(i.value.trim()==='')return;
  ask(i.value.trim());i.value='';
}
//]]>
</script>
</body>
</html>
</apex:page>
