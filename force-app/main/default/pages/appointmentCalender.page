<apex:page controller="CalenderManager" showHeader="false" sidebar="false" standardStylesheets="false">
    
    
    <link href="{!URLFOR($Resource.FullCalenderV4,  '/packages/core/main.css' )}" rel='stylesheet' />
    <link href="{!URLFOR($Resource.FullCalenderV4,  '/packages/daygrid/main.css' )}" rel='stylesheet' />
    <link href="{!URLFOR($Resource.FullCalenderV4,  '/packages/timegrid/main.css' )}" rel='stylesheet' />
    <link href="{!URLFOR($Resource.FullCalenderV4,  '/packages/list/main.css' )}" rel='stylesheet' />
    <apex:includeScript value="{!URLFOR($Resource.Full_Calendar_Master,  'v_2_0/lib/jquery.min.js')}" />

    <apex:includeScript value="{!URLFOR($Resource.FullCalenderV4,  '/packages/core/main.js' )}" />
    <apex:includeScript value="{!URLFOR($Resource.FullCalenderV4,  '/packages/interaction/main.js' )}" />
    <apex:includeScript value="{!URLFOR($Resource.FullCalenderV4,  '/packages/daygrid/main.js' )}" />
    <apex:includeScript value="{!URLFOR($Resource.FullCalenderV4,  '/packages/timegrid/main.js' )}" />
    <apex:includeScript value="{!URLFOR($Resource.FullCalenderV4,  '/packages/list/main.js' )}" />

    <style>
        html, body {
            margin: 0;
            padding: 0;
            font-family: Arial, Helvetica Neue, Helvetica, sans-serif;
            font-size: 14px;
        }
        
        #external-events {
            position: fixed;
            z-index: 2;
            top: 20px;
            left: 20px;
            width: 190px;
            padding: 0 10px;
            border: 1px solid #ccc;
            background: #eee;
            height:600px;
            overflow:scroll;
        }
        .fc-event{
            background-color:green !important;
        }
        .demo-topbar + #external-events { /* will get stripped out */
            top: 60px;
        }
        
        #external-events .fc-event,.fc-account{
            margin: 1em 0;
            cursor: move;
        }
        
        #calendar-container {
            position: relative;
            z-index: 1;
            margin-left: 200px;
        }
        
        #calendar {
            max-width: 900px;
            margin: 20px auto;
        }
        .closeon{
            float: right;
        }
        .fc-account{
            background-color:blue !important;
        }
         .fc-lead{
            background-color:darkred !important;
        }
        .fc-account, .fc-account:hover {
            color: #fff;
            text-decoration: none;
        }
        .fc-account {
            position: relative;
            display: block;
            font-size: 0.85em;
            line-height: 1.4;
            border-radius: 3px;
            border: 1px solid red;
        }
        .fc-time{
            display : none;
        }
        .approvebutton{ 
             float: right;
            margin-top: 10px;
            /* margin-bottom: 29px; */
            background-color: green;
            color: white;
            height: 30px; 
        
        }
         .rejectbutton{ 
             float: right;
            margin-top: 10px;
            /* margin-bottom: 29px; */
            background-color: red;
            color: white;
            height: 30px; 
        
        }
         .submitbutton{ 
             float: right;
            margin-top: 10px;
            /* margin-bottom: 29px; */
            background-color: black;
            color: white;
            height: 30px; 
        
        }
        
        .mainbutton{
        
         width: 85%;
         height: 35px;
        
        }
        .routeselect{
            float: left;
            margin-left: 200px;
            margin-top: 20px;
            font-size: 18px;
            font-weight: bold;
        }
    </style> 

    <script>
        var selectedRep='{!Representative[0].id}';  
        var calendar1;
        var Calendar = FullCalendar.Calendar;
        var deletedEvents = [];
        var deletedEventNames = [];
        document.addEventListener('DOMContentLoaded', function() {
            var Draggable = FullCalendarInteraction.Draggable;
            var containerEl = document.getElementById('external-events');
            var calendarEl = document.getElementById('calendar');
            var checkbox = document.getElementById('drop-remove');
            
            new Draggable(containerEl, {
                itemSelector: '.fc-event',
                eventData: function(eventEl) {
                    return {
                        title: eventEl.innerText,
                        className:'fc-event'
                    };
                }
            });
            
            new Draggable(containerEl, {
                itemSelector: '.fc-account',
                eventData: function(eventEl) {
                    return {
                        title: eventEl.innerText,
                        className:'fc-account'
                    };
                }
            });     
            
            // initialize the calendar
            // -----------------------------------------------------------------
            
            calendar1 = new Calendar(calendarEl, {  
                plugins: [ 'interaction', 'dayGrid', 'timeGrid' ],
                header: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,timeGridDay'
                },
                editable: true,
                eventClick:function( info ) {
                    if(info.jsEvent.target.innerHTML == 'X'){
                        info.jsEvent.preventDefault(); 
                    } 
                },
                eventRender: function(info) {
                    console.log(info.el.innerHTML);
                    info.el.innerHTML =  "<div class='closeon' style='width:10px;' onclick='deleteEvent(this);event.preventDefault();' data-id='"+info.event.url.replace('/','')+"'>X</div>" +info.el.innerHTML;
                },
                eventDrop: function(info) {
                    var obj = {}              
                    obj.startString  = info.event.start.toISOString();
                    obj.endString  = info.event.end ? info.event.end.toISOString() : info.event.start.toISOString();
                    obj.id = info.event.id;
                    console.log(info);
                    updateVisit( obj);
                },
                eventReceive:function(info ){ 
                    var obj = {}
                    obj.title = info.event.title;
                    obj.dealerId =  info.draggedEl.dataset.dealerid ;
                    obj.startString  = info.event.start.toISOString();
                    obj.ownerId = selectedRep ; 
                    var events = calendar1.getEvents();
                    for(var i=0;i<events.length;i++){
                        if(deletedEvents.indexOf(events[i]._def.id) > -1){
                            events[i].remove();
                        }
                    }
                    saveEvent(obj,info.event);  
                },
                eventDropfunction( eventDropInfo ) {
                    var obj = {}              
                    obj.startString  = eventResizeInfo.event.start.toISOString();
                    obj.endString  = eventResizeInfo.event.end.toISOString();
                    obj.id = eventResizeInfo.event.id;
                    console.log(eventDropInfo);
                    updateVisit( obj); 
                },
                eventResize:function( eventResizeInfo ) {
                    var obj = {}              
                    obj.startString  = eventResizeInfo.event.start.toISOString();
                    obj.endString  = eventResizeInfo.event.end.toISOString();
                    obj.id = eventResizeInfo.event.url.replace('/','');
                    console.log(obj);
                    updateVisit( obj);
                },
                events: function(info, successCallback, failureCallback ) {
                    fetchEvents(info.startStr,info.endStr,successCallback);  
                },
                drop: function(info) {
                    var id = info.draggedEl.dataset.dealerid;
                   
                    var recordType = info.draggedEl.className == 'fc-account' ? 'Account' : 'Store';
                   console.log(info);
                    var events = calendar1.getEvents();
                    for(var i=0;i<events.length;i++){
                        if((id == events[i].extendedProps.dealerId) || (!events[i].extendedProps.dealerId && info.draggedEl.innerText == events[i]._def.title)){
                            var d1 = info.date
                            var d2 = events[i].start;
                           
                           
                            if(d1.getFullYear() === d2.getFullYear() &&  d1.getMonth() === d2.getMonth() &&   d1.getDate() === d2.getDate() ){
                                 if(deletedEventNames.indexOf(info.draggedEl.innerText) < 0){  
                                    alert('This '+recordType+' is already assinged on this date.');
                                    info.revert();
                                 } else{
                                    deletedEventNames.pop(info.draggedEl.innerText);
                                 }
                            }
                        }
                    }
                    return false;  
                },
                droppable: true 
                
            });
            
            calendar1.render();
        });

        var events = [];

        function fetchEvents(startstr,endstr,successCallback){
            
            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.CalenderManager.showEvents}',
                selectedRep, startstr, endstr,
                function(result, event){
                    if (event.status) {
                        console.log(result);
                        var res;
                        res=JSON.parse(result);
                        events = [];
                        for(  var i=0;i<res.length;i++ ){
                            var o = res[i];
                            o.start = o.startString;
                            o.end = o.endString;
                            o.extendedProps = {'did': res[i].dealerId } 
                            events.push(o);
                        }
                        console.log(events)
                        successCallback(events)
                    }  
                }, 
                {escape: false}
            ); 
        }

        function saveEvent(obj,eve){
            
            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.CalenderManager.saveVisit}',
                obj,
                function(result, event){
                    if (event.status) {
                        eve.setProp('id',result+'' );
                        eve.setProp('url', '/'+result ); 
                    }  
                }, 
                {escape: false}
            ); 
        }  
        
        function updateVisit(obj){
            
            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.CalenderManager.updateVisit}',
                obj,
                function(result, event){
                    if (event.status) { 
                    }  
                }, 
                {escape: false}
            ); 
        }
        
        function showAccList(searchText){
            Visualforce.remoting.Manager.invokeAction(
                '{!$RemoteAction.CalenderManager.listRecords}', 
                selectedRep,searchText,
                function(result, event){
                    if (event.status) {
                        document.getElementById("accounts").innerHTML = '';   
                        for(  var i=0;i<result.length;i++ ){
                            var node = document.createElement("div"); 
                            node.setAttribute('data-dealerid',result[i].Id);
                            if(((result[i].Id).substring(0,3)) =='001'){
                                node.setAttribute('class','fc-account');    
                            }else{
                                node.setAttribute('class','fc-event');
                            }       
                            node.innerText = result[i].Name;
                            document.getElementById("accounts").appendChild(node);   
                        }
                    }  
                }, 
                {escape: false}
            ); 
        }
        
        function refetchEvents(sRep){
            selectedRep=sRep;
            showAccList('');
            calendar1.refetchEvents()
        }
        
        function deleteEvent(elem){
            //event.preventDefault();
            var visitId = elem.dataset.id;
            Visualforce.remoting.Manager.invokeAction('{!$RemoteAction.CalenderManager.deleteEvent}',visitId,function(result, event){
                //event.preventDefault();
                if (event.status) { 
                    var e = calendar1.getEventById(visitId)
                    if(e){
                        e.remove();
                    } else {
                        deletedEvents.push(elem.dataset.id);
                        deletedEventNames.push(elem.nextElementSibling.innerText);
                        elem.parentNode.remove();
                    }
                }  
            },{escape: false});  
        }
        
    </script>
    <script>
        window.setTimeout(function(){
            showAccList('');
        },2000)
    </script>
    <body>
        <apex:form >
            <apex:actionFunction name="setValue" reRender="selectedValue"> 
                <apex:param name="x" value="x" assignTo="{!selectedRep}"/>
            </apex:actionFunction>
            
            <apex:actionFunction name="setActiveTab" reRender="objectListId">
            </apex:actionFunction>
        </apex:form>
        <div id='external-events'> 
            <i> <b>Select user:</b>  </i>  
            <select onchange="refetchEvents(this.value)" style="margin-top:5px;margin-bottom:5px;max-width: 170px;"> 
               <!--  <apex:repeat value="{!Representative}" var="user">
                    <option value="{!user.Id}">{!user.Name}</option>
                </apex:repeat> -->
               <option  >Gynechology</option>
               <option  >Nephrology</option>
               <option  >Orthopediacs</option>
               <option  >Pediatrics</option>
               <option  >Cardiology</option>
                
            </select> 
            <div>
                <input type="text" value="" onkeyup="showAccList(this.value);" placeholder="Search..."/>
            </div>
             <div class="tab" id="accounts"> 
            </div> 
        </div>     
        <div id='calendar-container'>
            <div class="mainbutton">
            <select class="routeselect">
               <option>Dr. Anil Kumar(MBBS)</option>
               <option>Dr. Maya S(MBBS/MD)</option>
               <option>Dr. Manoj (Phd/MBBS/MD)</option>
               <option>Dr. John F(Phd/MBBS/MD)</option>
               <option>Dr Manoj(Phd/MBBS/MD)</option>
               <option>Dr. Perumal(Phd/MBBS/MD)</option>
             </select>
            
             
            </div>
            <div id='calendar'></div>
        </div> 
    </body>
</apex:page>