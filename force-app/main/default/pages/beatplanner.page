<apex:page controller="BeatPlanner" action="{!getbeatLineList}"> 
    
    <style>
        .beatplan{
        background-color:white;
        display: flex;
        
        flex-wrap: wrap;
        
        }
        .cell {
        
        width:180px;
        height:180px ;
        outline:1px solid grey;
        border:solid 1px grey;
        padding: 2px
        }
        .header{
        width:100%;
        height:20px;
        font-size:13px;
        text-align:center;
        font-weight:bold;
        }
        .store{
              width: 90%;
            height: 13px;
            text-align: left;
            font-size: 10px;
            font-family: Arial, Helvetica, sans-serif;
            background-color: green;
            margin: 4px;
            padding: 2px;
            padding-left: 5px;
            color: white;
            border-radius: 5px;
        }
        .storename{
           width:80%;
           float:left;
        
        }
         .storedelete{
               width: 15%;
                float: right;
                background-repeat: no-repeat;
                /* width: 20px; */
                height: 14px;
                cursor: pointer;
                text-align: right;
               background:url('{!$Resource.Delete}');
                background-size: contain;
               background-repeat: no-repeat;
            background-position-x: right;
            title:delete;


        }
    </style>    
    <div class="beatplan"> 
        
        <apex:repeat value="{!bmap}" var="day">
            <div class="cell">
                
                <div class="header"> Day {!day} </div> 
                <apex:repeat value="{!bmap[day]}" var="store">
                    <div class="store">
                        <div class="storename">
                            {!store.Account__r.Name}
                        </div>  
                        <div class="storedelete" title="delete this plan" onclick="confirmDelete('{!store.Id}')" id="{!store.Id}">
                            
                        </div>  
                    </div>
                </apex:repeat> 
            </div>
        </apex:repeat>
    </div> 
    <script>
    
      function confirmDelete(deleteId){  
           if (confirm("Confirm Delete this visit plan!") == true) {
               deleteVisitLine(deleteId);
            }   
      }
      function deleteVisitLine(deleteId){ 
          
            Visualforce.remoting.Manager.invokeAction(
            '{!$RemoteAction.BeatPlanner.deleteVisitPlan}',
            deleteId, 
            function(result, event){
                if (event.status) {
                   window.location.reload();
                }   
            }, 
            {escape: true}
        );
          
          
          
          
      }
    
    
    
    
    
    
    
    </script>
</apex:page>