  border-color: #f1c6c2;
}
.day.today {
  outline: 2px solid var(--orchid);
  outline-offset: 1px;
}
.day .tag {
  position: absolute;
  top: 6px;
  right: 6px;
  font-size: 9.5px;
  font-weight: 700;
  color: var(--orchid);
}

/* Forms / buttons */
.form .field {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-bottom: 10px;
  font-size: 12.5px;
  color: var(--muted);
}
.form .field input,
.form .field select,
.form .field textarea {
  font-size: 14px;
  padding: 8px;
  border: 1px solid var(--line);
  border-radius: 8px;
  color: var(--ink);
  font-family: inherit;
}
.btn {
  font-size: 14px;
  padding: 9px 14px;
  border-radius: 8px;
  border: 1px solid transparent;
  cursor: pointer;
  font-weight: 600;
}
.btn-primary {
  background: var(--orchid);
  color: #fff;
  width: 100%;
}
.btn-primary:hover {
  background: var(--orchid-dark);
}
.btn-primary:disabled {
  background: #c9b3c2;
  cursor: not-allowed;
}
.btn-ghost {
  background: #fff;
  border-color: var(--line);
  color: var(--ink);
  font-weight: 500;
  font-size: 12.5px;
  padding: 6px 10px;
}
.btn-sm {
  padding: 5px 10px;
  font-size: 12px;
}
.btn-approve {
  background: var(--green-bg);
  color: var(--green);
  border-color: #bfe3c9;
}
.btn-reject {
  background: var(--red-bg);
  color: var(--red);
  border-color: #f1c6c2;
}

.window-msg {
  font-size: 12.5px;
  border-radius: 8px;
  padding: 10px 12px;
  margin-bottom: 12px;
  display: none;
}
.window-msg.show {
  display: block;
}
.window-msg.locked {
  background: var(--red-bg);
  color: #7d1d18;
  border: 1px solid #f1c6c2;
}
.window-msg.ok {
  background: var(--green-bg);
  color: #18532e;
  border: 1px solid #bfe3c9;
}
.form.disabled {
  opacity: 0.55;
  pointer-events: none;
}

/* Pills / deviation list */
.pill {
  background: var(--orchid-light);
  color: var(--orchid);
  font-size: 11.5px;
  font-weight: 700;
  padding: 2px 9px;
  border-radius: 999px;
}
.dev-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.dev-item {
  border: 1px solid var(--line);
  border-radius: 10px;
  padding: 10px 12px;
}
.dev-item .dev-top {
  display: flex;
  justify-content: space-between;
  gap: 8px;
  align-items: center;
}
.dev-item .dev-type {
  font-weight: 700;
  font-size: 13px;
}
.dev-item .dev-meta {
  font-size: 11.5px;
  color: var(--muted);
}
.dev-item .dev-reason {
  font-size: 12.5px;
  margin-top: 6px;
  color: #333;
}
.dev-actions {
  display: flex;
  gap: 6px;
  margin-top: 8px;
}
.status {
  font-size: 11px;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 999px;
}
.status.Pending {
  background: var(--amber-bg);
  color: var(--amber);
}
.status.Approved {
  background: var(--green-bg);
  color: var(--green);
}
