<aura:component Controller="storePhotosController"
                implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,force:lightningQuickAction" access="global" >
	<aura:attribute name="recordId" type="Id" />
    <aura:attribute name="visitPhotos" type="String[]"/> 
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"></aura:handler>
    <lightning:carousel disableAutoScroll="true">
        <aura:if isTrue="{!v.visitPhotos !=null}">
        <aura:iteration items="{!v.visitPhotos}" var="vp" indexVar="ind">
            
         <lightning:carouselImage
                                 src = "{!vp.url}" 
                                 header = "{!vp.visitId}" 
                                 description = "{!vp.createdDate}"
                                 >
        </lightning:carouselImage>
          
    </aura:iteration>
            <aura:set attribute="else">
                  <lightning:carouselImage
                                 src = "" 
                                 header = "" 
                                 description = "NoPhotos"
                                 >
        </lightning:carouselImage>
             </aura:set>
        </aura:if>
        
    </lightning:carousel>
</aura:component>