                                </aura:if>
                            </aura:iteration>
                        </table>
                        
                        
                    </div>
                    
                    
                </div>  
            </div>
        </div>-->
        
        <!-- VISIT BY CUSTOMER TYPE SECTION -->
        <div class="slds-card slds-has-bottom-magnet slds-has-top-magnet">
            <div class="slds-p-around_medium">
                <div class="slds-box " style="padding-left: 5vw;">
                    <div style="padding-bottom:10px;"> <span><lightning:icon iconName="standard:dashboard" alternativeText="Preview" title="Preview" />
                        &nbsp;<b><u>Visit by Customer Type - {!v.curMonth}</u></b></span>
                    </div>
                    <div>
                        <table style="width:100%">
                            
                            <tr>
                                
                                <th><div class="trow"> <div class="slds-float-left"> 
                                    <u>Purpose</u></div></div></th>
                                <th><div class="trow"> <div class="slds-float-left">  
                                    <u>Planned</u></div></div></th>
                                <th><div class="trow"> <div class="slds-float-left">  
                                    <u>Completed</u></div></div></th>
                            </tr>
                            <tr>&nbsp;</tr>
                            <aura:iteration items="{!v.data.visits}" var="val"  indexVar="index">
                                <aura:if isTrue="{!val.cusType != null}">
                                    <tr>
                                        <th class="tdata">
                                            <div class="trow">
                                                <div class="slds-float-left">  
                                                    {!val.cusType}
                                                </div>
                                            </div>
                                        </th>
                                        <td class="tdata">
                                            <div class="trow red">
                                                <div class="slds-float-left">
                                                    <img class="ticon" src="{!$Resource.TargetIcon}"></img>
                                                </div> 
                                                <div class="slds-float-left">  
                                                    {!val.planned}  
                                                </div>  
                                            </div>
                                        </td>
                                        <td class="tdata">
                                            <div class="trow green">
                                                <div class="slds-float-left">
                                                    <img class="ticon" src="{!$Resource.acheivement}"></img>
                                                </div> 
                                                <div class="slds-float-left">  
                                                    {!val.completed}
                                                </div>  
                                            </div>
                                        </td>
                                    </tr>
                                </aura:if>
                            </aura:iteration>
                        </table>
                        
                        
                    </div>
                    
                    
                </div>  
            </div>
        </div>
        
        <div class="slds-card slds-has-bottom-magnet slds-has-top-magnet">
            <div class="slds-p-around_medium">
                <div class="slds-grid slds-wrap">
                    <div id="column-1" class="slds-size_1-of-2 slds-flex" style="padding-right:5px">
                        <div class="slds-box ">
                            <div style="padding-bottom:10px;"> 
                                <span><lightning:icon iconName="standard:visits" alternativeText="Preview" title="Preview" />
                                    &nbsp;<b><u>Hospitals Visits Plan</u></b></span>
                            </div>
                            <div>
                                <table>
                                    
                                    <tr>
                                        <th class="thead"> <span class="black"> Core Visits : </span></th>
                                        <td class="tdata"> <div class="trow green">43</div></td>
                                    </tr>
                                    
                                    
                                    <tr>
                                        <th class="thead"> <span class="black">  VIP Visits : </span></th>
                                        <td class="tdata"> <div class="trow green"> 12</div></td>
                                    </tr>
                                    
                                    <tr>
                                        <th class="thead"> <span class="black"> Super Core Visits : </span></th>
                                        <td class="tdata"> <div class="trow green"> 33</div></td>
                                    </tr>
                                    
                                    <tr>
                                        <th class="thead"> <span class="black"> Regular Visits : </span></th>
                                        <td class="tdata"> <div class="trow green"> 41</div></td>
                                    </tr>
                                    
                                </table>
                            </div>
                            <!--  <div class="trow green"><div class="slds-float-left"> <span class="black"> Platinum Visits : </span> {!v.data.distplat} </div>  </div>
                            <div class="trow green"><div class="slds-float-left"> <span class="black"> Gold Visits : </span> {!v.data.distgold}</div>  </div>
                            <div class="trow green"><div class="slds-float-left"> <span class="black"> Silver Visits : </span> {!v.data.distsil} </div>  </div>
                            <div class="trow green"><div class="slds-float-left"> <span class="black"> Regular Visits : </span> {!v.data.distreg} </div>  </div>-->
                        </div>  
                    </div>
                    <div id="column-2" class="slds-size_1-of-2 slds-flex" style="padding-left:5px">
                        <div class="slds-box ">
                            <div style="padding-bottom:10px;"> 
                                <span><lightning:icon iconName="standard:visits" alternativeText="Preview" title="Preview" />
                                    &nbsp;<b><u>Distributers Visits Plan</u></b></span>
                            </div>
                            <div>
                                <table>
                                    
                                    <tr>
                                        <th class="thead"> <span class="black"> Platinum Visits : </span></th>
                                        <td class="tdata"> <div class="trow green"> 34</div></td>
                                    </tr>
                                    
                                    
                                    <tr>
                                        <th class="thead"> <span class="black">  Gold Visits : </span></th>
                                        <td class="tdata"> <div class="trow green"> 29</div></td>
                                    </tr>
                                    
                                    <tr>
                                        <th class="thead"> <span class="black"> Silver Visits : </span></th>
                                        <td class="tdata"> <div class="trow green">27</div></td>
                                    </tr>
                                    
                                    <tr>
                                        <th class="thead"> <span class="black"> Regular Visits : </span></th>
                                        <td class="tdata"> <div class="trow green"> 22</div></td>
                                    </tr>
                                    
                                </table>
                            </div>
                            <!-- <div class="trow green"><div class="slds-float-left"> <span class="black"> Platinum Visits : </span> {!v.data.dealplat} </div>  </div>
                            <div class="trow green"><div class="slds-float-left"> <span class="black"> Gold Visits : </span> {!v.data.dealgold} </div>  </div>
                            <div class="trow green"><div class="slds-float-left"> <span class="black"> Silver Visits : </span> {!v.data.dealsil} </div>  </div>
                            <div class="trow green"><div class="slds-float-left"> <span class="black"> Regular Visits : </span> {!v.data.dealreg} </div>  </div>
                            -->                        
                        </div>  
                    </div>
                </div>
            </div> 
        </div>   
        
