<aura:component   implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" access="global" >
    
    <aura:attribute name="topSellers" type="object[]" />
    <aura:attribute name="data" type="Object" />
    <aura:attribute name="lastMonth" type="String" />
    <aura:attribute name="curMonth" type="String" />
    <aura:attribute name="targetNames"  type="String[]" default="[]"/>
    
    <aura:handler name="init" value="{!this}" action="{!c.doInit}"></aura:handler>  
    
    
    
    <div>
        <!-- BEST PERFORMERS SECTION -->
        <aura:if isTrue="{!v.topSellers}">
            <div class="slds-card slds-has-bottom-magnet"> 
                <div class="slds-p-around_medium">
                    <div class="slds-box " style="padding-left: 5vw;"> 
                        <span><lightning:icon iconName="custom:custom48" alternativeText="Preview" title="Preview" />
                            &nbsp;<b><u>Best performers of the {!v.lastMonth}</u></b></span>
                        <aura:iteration items="{!v.topSellers}" var="val"  indexVar="index">
                            <div class="trow1 golden"><img class="ticon1" src="{!$Resource.Crown}"></img> <div class="slds-float-left"><div class="leadertext1">{!index+1}<sup><aura:if isTrue="{!index+1 == 1}">st</aura:if><aura:if isTrue="{!index+1 == 2}">nd</aura:if></sup> </div></div><div class="slds-float_left"> <div class="leadertext2 black">&nbsp;&nbsp;&nbsp; {!val}</div> </div>   </div>
                        </aura:iteration>
                        <!--  <div class="trow1 golden"><img class="ticon1" src="{!$Resource.Crown}"></img> <div class="slds-float-left"><div class="leadertext1">1<sup>st</sup> </div></div><div class="slds-float_left"> <div class="leadertext2 black">&nbsp;&nbsp;&nbsp; Rakesh Reddy</div> </div>   </div>
                     <div class="trow1 golden"><img class="ticon1" src="{!$Resource.Crown}"></img><div class="slds-float-left"><div class="leadertext1">2<sup>nd</sup> </div></div><div class="slds-float_left"> <div class="leadertext2 black">&nbsp;&nbsp;&nbsp; Arun Kumar</div> </div>   </div>-->
                    </div>  
                </div> 
            </div>
        </aura:if>
        
        <!-- KPI SECTION -->
        <div class="slds-card slds-has-bottom-magnet slds-has-top-magnet">
            <div class="slds-p-around_medium">
                <div class="slds-box " style="padding-left: 5vw;">
                    <div style="padding-bottom:10px;"> <span><lightning:icon iconName="standard:dashboard" alternativeText="Preview" title="Preview" />
                        &nbsp;<b><u>KPIs for {!v.curMonth}</u></b></span>
                    </div>
                    <div>
                        <table style="width:100%">
                            
                            <tr>
                                
                                <th><div class="trow"> <div class="slds-float-left"> 
                                    <u>Target</u></div></div></th>
                                <th><div class="trow"> <div class="slds-float-left">  
                                    <u>Target Value</u></div></div></th>
                                <th><div class="trow"> <div class="slds-float-left">  
                                    <u>Actual value</u></div></div></th>
            
                            </tr>
                            <tr>&nbsp;</tr>
                            <aura:iteration items="{!v.data.targets}" var="val"  indexVar="index">
                                <tr>
                                    <th class="tdata">
                                        <div class="trow">
                                            <div class="slds-float-left">  
                                                {!val.targetName}
                                            </div>
                                        </div>
                                    </th>
                                    <td class="tdata">
                                        <div class="trow red">
                                            <div class="slds-float-left">
                                                <img class="ticon" src="{!$Resource.TargetIcon}"></img>
                                            </div> 
                                            <div class="slds-float-left">  
                                                <span class="black">₹</span>&nbsp;{!val.target}  
                                            </div>  
                                        </div>
                                    </td>
                                    <td class="tdata">
                                        <div class="trow green">
                                            <div class="slds-float-left">
                                                <img class="ticon" src="{!$Resource.acheivement}"></img>
                                            </div> 
                                            <div class="slds-float-left">  
                                                <span class="black">₹</span>&nbsp;{!val.actual}
                                            </div>  
                                        </div>
                                    </td>
                                    
                                </tr>
                            </aura:iteration>
                        </table>
                        
                        
                    </div>
                    
                    <!-- <p><b>My Target</b></p>
                    <div class="trow green"><div class="slds-float-left"><img class="ticon" src="{!$Resource.TargetIcon}"></img></div> <div class="slds-float-left">  <aura:if isTrue="{!not(empty(v.data))}"><span class="black">₹</span>&nbsp;{!v.data.target}  <aura:set attribute="else">N/A</aura:set></aura:if> </div>  </div>
                    <p><b>My Achievement</b></p> 
                    <div class="trow red"><div class="slds-float-left"><img class="ticon" src="{!$Resource.acheivement	}"></img></div> <div class="slds-float-left">  <aura:if isTrue="{!not(empty(v.data))}"><span class="black">₹</span>&nbsp;{!v.data.actual}  <aura:set attribute="else">N/A</aura:set></aura:if> </div>  </div>
                    <p><b>CY YTD Sales</b></p>
                    <div class="trow golden"><div class="slds-float-left"></div> <div class="slds-float-left">  <aura:if isTrue="{!not(empty(v.data))}"><span class="black">₹</span>&nbsp;{!v.data.cysales}  <aura:set attribute="else">N/A</aura:set></aura:if> </div>  </div>
                    <p><b>LY YTD Sales</b></p>
                    <div class="trow golden"><div class="slds-float-left"></div> <div class="slds-float-left">  <aura:if isTrue="{!not(empty(v.data))}"><span class="black">₹</span>&nbsp;{!v.data.lysales}  <aura:set attribute="else">N/A</aura:set></aura:if> </div>  </div>
                    <p><b>GAP</b></p>
                    <div class="trow golden"><div class="slds-float-left"></div> <div class="slds-float-left"><span class="black">₹</span> 1,50,200 </div>  </div> 
                    <p><b>Quota</b></p>
                    <div class="trow golden"><div class="slds-float-left"></div> <div class="slds-float-left"><span class="black">₹</span> 2,50,200 </div>  </div>
                    -->
                    
                </div>  
            </div>
        </div>
        
       <!-- VISIT BY PURPOSE SECTION -->
        <!-- <div class="slds-card slds-has-bottom-magnet slds-has-top-magnet">
            <div class="slds-p-around_medium">
                <div class="slds-box " style="padding-left: 5vw;">
                    <div style="padding-bottom:10px;"> <span><lightning:icon iconName="standard:dashboard" alternativeText="Preview" title="Preview" />
